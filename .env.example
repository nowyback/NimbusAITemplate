# Discord Bot Configuration
DISCORDBOTTOKEN=YOUR_ACTUAL_BOT_TOKEN
VERSION=X.X.X
OWNER_ID=BOT_OWNER_ID
DEFAULT_MODEL=SET_YOUR_DEFAULT_MODEL_HERE
REQUEST_COOLDOWN=5
DEFAULT_TOKENS=1

# Internet Access Configuration
# Set to 'true' to enable internet features
INTERNET_ACCESS=false

# Access method: 'search', 'fetch', or 'hybrid'
# search: Only web search (DuckDuckGo)
# fetch: Only direct URL fetching  
# hybrid: Both search and URL fetching
INTERNET_METHOD=search

# Allowed domains (comma-separated, leave empty for all)
# Examples: wikipedia.org,github.com,stackoverflow.com
ALLOWED_DOMAINS=wikipedia.org,github.com,stackoverflow.com

# Rate limit: requests per minute per user
RATE_LIMIT=10

# Optional: Custom settings
# MAX_PROMPT_LOG_ENTRIES=1000
# BOT_PREFIX=>
# HELP_PREFIX=?

# Internet Access Commands:
# > search [query] - Search the web (if enabled)
# > fetch [URL] - Get content from URL (if enabled)  
# > internet on/off - Toggle access (owner only)