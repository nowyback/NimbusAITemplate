# Discord Bot Configuration
DISCORDBOTTOKEN=YOUR_ACTUAL_BOT_TOKEN
VERSION=X.X.X
OWNER_ID=BOT_OWNER_ID
DEFAULT_MODEL=SET_YOUR_DEFAULT_MODEL_HERE
REQUEST_COOLDOWN=5
DEFAULT_TOKENS=1

# Internet Access Configuration
INTERNET_ACCESS=false

# Chat Session Configuration
SESSION_TIMEOUT=259200000
MAX_SESSIONS_PER_USER=5
MAX_MESSAGES_PER_SESSION=50

# Server Building Configuration
ARCHIVE_CATEGORY_NAME=Archive
DELETE_ROLES_ON_MOVE=true
CREATE_ARCHIVE_CATEGORY_IF_MISSING=true

# AI Configuration
AI_NAME=Nimbus AI
AI_RESPONSE_PREFIX=Nimbus AI Response
AI_PROCESSING_PREFIX=AI is generating
AI_ERROR_PREFIX=AI encountered an error

# Content Censoring Configuration
CENSORING_LEVEL=2

# Optional: Custom settings
MAX_PROMPT_LOG_ENTRIES=1000
BOT_PREFIX=>
HELP_PREFIX=?

# 0 = No censoring
# 1 = Just IPs, Addresses, etc
# 2 = A bit more censoring
# 3 = Normal Censorship
# 4 = Heavy Censoring
# 5 = Extreme Censoring

# Optional: Custom settings
# MAX_PROMPT_LOG_ENTRIES=1000
# BOT_PREFIX=>
# HELP_PREFIX=?

# Internet Access Commands:
# > search [query] - Search the web (if enabled)
# > fetch [URL] - Get content from URL (if enabled)  
# > internet on/off - Toggle access (owner only)

# Chat Session Commands:
# > clear/reset - Clear current chat session
# > session - Show session information