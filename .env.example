# Discord Bot Configuration
DISCORDBOTTOKEN=YOUR_ACTUAL_BOT_TOKEN
VERSION=X.X.X
OWNER_ID=BOT_OWNER_ID
DEFAULT_MODEL=SET_YOUR_DEFAULT_MODEL_HERE
REQUEST_COOLDOWN=5
DEFAULT_TOKENS=1

# Internet Access Configuration
INTERNET_ACCESS=false # Set to 'true' to enable internet features
INTERNET_METHOD=hybrid # search: Only web search (DuckDuckGo), fetch: Only direct URL fetching, hybrid: Both search and URL fetching
ALLOWED_DOMAINS=wikipedia.org,github.com,stackoverflow.com # Examples: wikipedia.org,github.com,stackoverflow.com (comma-separated, leave empty for all)

# Rate limit: requests per minute per user
RATE_LIMIT=10

# Chat Session Configuration
# Session timeout in milliseconds (3 days = 259200000)
SESSION_TIMEOUT=259200000
MAX_SESSIONS_PER_USER=5
MAX_MESSAGES_PER_SESSION=50

# Content Censoring Configuration
CENSORING_LEVEL=2
# 0 = No censoring
# 1 = Just IPs, Addresses, etc
# 2 = A bit more censoring
# 3 = Normal Censorship
# 4 = Heavy Censoring
# 5 = Extreme Censoring

# Optional: Custom settings
# MAX_PROMPT_LOG_ENTRIES=1000
# BOT_PREFIX=>
# HELP_PREFIX=?

# Internet Access Commands:
# > search [query] - Search the web (if enabled)
# > fetch [URL] - Get content from URL (if enabled)  
# > internet on/off - Toggle access (owner only)

# Chat Session Commands:
# > clear/reset - Clear current chat session
# > session - Show session information